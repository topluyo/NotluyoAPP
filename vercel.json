{
  "rewrites": [
    {
      "source": "/@:usernick",
      "destination": "/u/:usernick"
    },
    {
      "source": "/@:usernick/:bordslug",
      "destination": "/u/:usernick/:bordslug"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 */6 * * *"
    }
  ]
}
